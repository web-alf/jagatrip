---
import { SITE } from '../../../data/site';

const waLink = `https://wa.me/${SITE.waNumber}?text=${encodeURIComponent('Halo admin, saya mau daftar JAGATRIP Malaysia-Thailand (24-28 Juni 2026). Mohon info lebih lanjut. Terimakasih.')}`;

const includes = [
  { icon: '🏨', label: 'HOTEL', desc: 'Penginapan nyaman selama 4 malam' },
  { icon: '🍽️', label: '11x MAKAN', desc: 'Termasuk sarapan, makan siang, dan makan malam pilihan' },
  { icon: '🥂', label: 'WELCOME DRINK', desc: 'Minuman sambutan di hari pertama' },
  { icon: '🚌', label: 'BUS PARIWISATA LUXURY', desc: 'Transportasi darat Malaysia–Thailand (VIP)' },
  { icon: '📚', label: 'WORKSHOP & SEMINAR KIT', desc: 'Modul, buku, dan alat tulis' },
  { icon: '🛍️', label: 'MERCHANDISE JAGATRIP', desc: 'Souvenir eksklusif Insider Series' },
  { icon: '🎁', label: 'DOOR PRIZE', desc: 'Hadiah menarik untuk peserta beruntung' },
  { icon: '🥇', label: 'SERTIFIKAT RESMI', desc: 'Sertifikat benchmarking internasional dari PT Jagatrip Mitra Edukasi' },
  { icon: '📸', label: 'DOKUMENTASI', desc: 'Foto dan video profesional selama perjalanan' },
  { icon: '🗺️', label: 'CITY TOUR', desc: 'Tur kota KL, Hatyai, KL Perlis' },
  { icon: '👨‍🏫', label: 'TOUR LEADER PROFESIONAL', desc: 'Pendamping berpengalaman selama perjalanan' },
  { icon: '🛡️', label: 'ASURANSI PERJALANAN', desc: 'Perlindungan selama program berlangsung' },
];

const excludes = [
  { icon: '✈️', label: 'Tiket pesawat' },
  { icon: '🛂', label: 'Paspor' },
  { icon: '🧳', label: 'Bagasi tambahan' },
  { icon: '🛍️', label: 'Pengeluaran pribadi (cth: laundry, jajan, oleh-oleh)' },
  { icon: '🗺️', label: 'Biaya tambahan tour wisata di luar jadwal resmi' },
  { icon: '🛏️', label: 'Single Supplement: biaya tambahan bagi peserta yang ingin tidur sendiri' },
];
---

<section id="pricing" class="py-24 bg-white border-t border-gray-200">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">
        Kamu Tinggal Hadir dan Belajar
      </h2>
      <p class="text-2xl md:text-3xl font-bold text-jaga-orange">
        Karena Semua sudah Include:
      </p>
    </div>

    <!-- Price header -->
    <div class="bg-gray-900 text-white rounded-3xl p-6 md:p-8 mb-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
      <div>
        <p class="text-sm font-bold uppercase tracking-widest text-white/70 mb-1">Harga</p>
        <p class="text-3xl sm:text-4xl md:text-5xl font-black">Rp 7.000.000 <span class="text-base sm:text-lg font-bold text-white/70">/ orang</span></p>
      </div>
      <a
        href="#daftar"
        class="bg-jaga-orange hover:bg-jaga-orange-600 text-white font-black text-sm px-8 py-3 rounded-full shadow-lg hover:shadow-xl transition-all shrink-0"
      >
        Daftar Sekarang
        <svg class="w-4 h-4 inline-block ml-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

    <!-- Include items -->
    <div class="grid sm:grid-cols-2 gap-4 mb-10">
      {includes.map((item, i) => (
        <div class={`flex items-start bg-jaga-bg p-5 rounded-xl border border-gray-100${i === includes.length - 1 && includes.length % 2 !== 0 ? ' sm:col-span-2 sm:max-w-sm sm:mx-auto' : ''}`}>
          <span class="text-2xl mr-4 shrink-0">{item.icon}</span>
          <div>
            <p class="text-gray-900 font-bold leading-tight">{item.label}</p>
            <p class="text-gray-500 text-sm mt-0.5">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Exclude -->
    <div class="mb-8">
      <div class="text-center mb-5">
        <span class="inline-block bg-red-50 border border-red-200 text-red-700 font-black text-xs md:text-sm uppercase tracking-[0.25em] px-5 py-2 rounded-full">
          ⚠️ Exclude
        </span>
        <p class="mt-2 text-gray-500 text-sm">
          Hal-hal berikut <strong class="text-gray-900">tidak termasuk</strong> dalam paket:
        </p>
      </div>
      <ul class="grid sm:grid-cols-2 gap-3">
        {excludes.map((item) => (
          <li class="flex items-start gap-3 bg-red-50/40 border border-red-100 rounded-xl px-4 py-3">
            <span class="text-xl shrink-0">{item.icon}</span>
            <span class="text-gray-700 text-sm md:text-base font-medium leading-relaxed">{item.label}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="bg-orange-50 border border-orange-200 rounded-2xl p-6">
      <p class="text-gray-800 text-base leading-relaxed text-center">
        <span class="font-bold text-jaga-orange uppercase mr-2">CATATAN PENTING:</span>
        Meeting Point Keberangkatan: KLIA (Kuala Lumpur International Airport).
        Harga bervariasi sesuai kota keberangkatan.
      </p>
    </div>
  </div>
</section>
