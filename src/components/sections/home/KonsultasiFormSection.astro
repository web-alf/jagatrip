---
const inputClass = 'w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-jaga-orange focus:outline-none text-gray-900 placeholder:text-gray-400 text-sm font-medium transition-colors bg-white';
---

<section id="daftar" class="py-20 md:py-28 bg-linear-to-br from-gray-900 via-gray-800 to-gray-900 text-white relative overflow-hidden">

  <!-- Decorative -->
  <div class="absolute top-10 right-10 w-64 h-64 bg-jaga-orange/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-80 h-80 bg-jaga-orange/10 rounded-full blur-3xl"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-start">

      <!-- Left: copy -->
      <div class="lg:sticky lg:top-32">
        <span class="inline-block bg-jaga-orange text-white font-black text-xs md:text-sm uppercase tracking-[0.3em] px-5 py-2 rounded-full mb-6 shadow-lg">
          📝 Form Pendaftaran
        </span>

        <h2 class="text-3xl md:text-5xl font-black tracking-tight leading-tight mb-6">
          Daftar Sekarang & <span class="text-jaga-orange">Amankan Kursimu</span>
        </h2>

        <p class="text-lg md:text-xl text-gray-300 leading-relaxed mb-8">
          Isi formulir pendaftaran — data kamu akan tersimpan otomatis dan admin JAGATRIP akan menghubungimu via WhatsApp dalam <strong class="text-white">1×24 jam</strong> untuk konfirmasi.
        </p>

        <ul class="space-y-4 text-base text-gray-300">
          <li class="flex items-start gap-3">
            <span class="shrink-0 w-8 h-8 rounded-full bg-jaga-orange/20 flex items-center justify-center text-jaga-orange font-black text-sm mt-0.5">1</span>
            <div>
              <p class="font-bold text-white">Isi formulir pendaftaran</p>
              <p class="text-sm text-gray-400">Data tersimpan otomatis ke sistem kami</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="shrink-0 w-8 h-8 rounded-full bg-jaga-orange/20 flex items-center justify-center text-jaga-orange font-black text-sm mt-0.5">2</span>
            <div>
              <p class="font-bold text-white">Konfirmasi via WhatsApp</p>
              <p class="text-sm text-gray-400">Otomatis redirect ke WhatsApp admin</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="shrink-0 w-8 h-8 rounded-full bg-jaga-orange/20 flex items-center justify-center text-jaga-orange font-black text-sm mt-0.5">3</span>
            <div>
              <p class="font-bold text-white">Admin follow-up dalam 1×24 jam</p>
              <p class="text-sm text-gray-400">Diskusi detail program & pembayaran</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Right: form -->
      <div class="bg-white text-gray-900 rounded-4xl p-6 md:p-8 shadow-[0_25px_60px_rgba(0,0,0,0.4)]">
        <p class="text-xl md:text-2xl font-black text-gray-900 mb-1">Formulir Pendaftaran</p>
        <p class="text-sm text-gray-500 mb-6">Lengkapi data berikut untuk mendaftar program JAGATRIP.</p>

        <form id="daftar-form" novalidate class="space-y-3">

          <!-- Nama -->
          <div>
            <label for="f-nama" class="block text-xs font-bold text-gray-600 uppercase tracking-wider mb-1">Nama Lengkap *</label>
            <input id="f-nama" name="nama" type="text" required placeholder="Nama lengkap Anda" class={inputClass} />
          </div>

          <!-- WA -->
          <div>
            <label for="f-wa" class="block text-xs font-bold text-gray-600 uppercase tracking-wider mb-1">No. WhatsApp *</label>
            <input id="f-wa" name="wa" type="tel" required inputmode="numeric" placeholder="081234567890" class={inputClass} />
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-jaga-orange hover:bg-jaga-orange-600 text-white font-black text-base md:text-lg py-4 rounded-full shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-0.5 mt-4"
          >
            Kirim & Lanjut ke WhatsApp →
          </button>

          <!-- Status message -->
          <div id="form-status" class="hidden"></div>

          <p class="text-xs text-gray-400 text-center mt-3 leading-relaxed">
            🔒 Data kamu aman & tersimpan otomatis. Setelah submit, kamu akan diarahkan ke WhatsApp admin untuk konfirmasi.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border-width: 0;
  }
</style>

<script>
  import { initRegistrationForm } from '../../../lib/form-handler';
  initRegistrationForm();
</script>
