---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="JAGATALK by JAGATRIP — Webinar Gratis Kuliah Luar Negeri"
  description="Series webinar gratis dari JAGATRIP. Dengar langsung pengalaman kuliah di luar negeri dari mahasiswa & alumni IDN yang sedang menjalani. Dunia Lebih Dekat."
  gtmId="GTM-NR8XFKP9"
>
  <main id="main" class="jt">

    <!-- SVG DEFS -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <symbol id="jagatalk-logo" viewBox="0 0 100 100">
          <path d="M50 5 C30 5, 15 10, 12 25 L12 55 C12 78, 30 92, 50 95 C70 92, 88 78, 88 55 L88 25 C85 10, 70 5, 50 5 Z" fill="none" stroke="#0E7C86" stroke-width="6" stroke-linejoin="round"/>
          <rect x="30" y="34" width="40" height="26" rx="7" fill="#FF6B1A"/>
          <path d="M36 60 L32 70 L46 60 Z" fill="#FF6B1A"/>
          <circle cx="42" cy="47" r="2.5" fill="white"/><circle cx="50" cy="47" r="2.5" fill="white"/><circle cx="58" cy="47" r="2.5" fill="white"/>
        </symbol>
        <symbol id="jagatrip-logo" viewBox="0 0 100 100">
          <path d="M50 5 C30 5, 15 10, 12 25 L12 55 C12 78, 30 92, 50 95 C70 92, 88 78, 88 55 L88 25 C85 10, 70 5, 50 5 Z" fill="none" stroke="#FF6B1A" stroke-width="6" stroke-linejoin="round"/>
          <circle cx="50" cy="48" r="11" fill="#FF6B1A"/>
          <path d="M76 14 l4 -3 l2 4 l4 -2 l-2 5 l3 3 l-5 1 l-2 4 l-2 -4 l-5 -1 l3 -3 z" fill="#FF6B1A"/>
        </symbol>
      </defs>
    </svg>

    <!-- NAV -->
    <nav class="jt-nav">
      <div class="jt-nav-inner">
        <a href="/jagatalk" class="jt-logo-wrap">
          <svg class="jt-logo-svg"><use href="#jagatalk-logo"></use></svg>
          <div>
            <div class="jt-logo-text"><span class="jaga">jaga</span><span class="talk">talk</span></div>
            <span class="jt-logo-sub">by JAGATRIP</span>
          </div>
        </a>
        <div class="jt-nav-actions">
          <a class="jt-nav-link-jadwal" href="#jadwal">Jadwal Webinar</a>
          <a class="jt-nav-cta" href="#final-cta">Daftar Webinar <svg class="jt-arrow" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="jt-hero" data-reveal="hero">
      <div class="jt-hero-inner">
        <div>
          <div class="jt-hero-tag"><span class="jt-dot"></span> WEBINAR GRATIS · SETIAP MINGGU</div>
          <h1>Mau Kuliah di Luar Negeri Tapi <span class="accent-teal">Bingung Mulai dari Mana?</span></h1>
          <p class="jt-hero-sub2"><span class="accent-orange">Dapatkan Cerita Jujur & Strategi Riil Langsung dari Mereka yang Sudah di Sana.</span></p>
          <p class="jt-sub">Saatnya dengar cerita jujur, angka riil, dan pengalaman nyata langsung dari mahasiswa Indonesia yang sedang berjuang di sana. Tanpa sensor, tanpa clickbait.</p>
          <div class="jt-hero-ctas">
            <a class="jt-btn-primary" href="#final-cta">🎯 Amankan Kursi Anda Sekarang!</a>
          </div>
          <p style="margin-top:20px; font-size:13px; color:var(--jt-gray);"><strong style="color:var(--jt-charcoal);">100% Gratis</strong> · Online via Zoom · Rekaman webinar untuk peserta hadir</p>
        </div>

        <div style="position:relative;">
          <div class="jt-hero-card">
            <div class="jt-hero-card-bg">
              <img src="/jagatalk-general.webp" alt="JAGATALK — Info & Jadwal Webinar Kuliah Luar Negeri" class="jt-hero-card-img" />
            </div>
            <div class="jt-hero-card-body">
              <h3 style="font-size:18px;font-weight:900;color:var(--jt-charcoal);line-height:1.2;">MENGUPAS REALITA &amp; RAHASIA KULIAH DI LUAR NEGERI</h3>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="jt-stats" data-reveal="section">
      <div class="jt-stats-inner">
        <div><span class="sn">10+</span><span class="sl">Negara Tujuan Pembahasan</span></div>
        <div><span class="sn">30+</span><span class="sl">Narasumber</span></div>
        <div><span class="sn">100%</span><span class="sl">Gratis & Online</span></div>
        <div><span class="sn">1x</span><span class="sl">Webinar Setiap Minggu</span></div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="jt-section" id="about" data-reveal="section">
      <div class="jt-inner">
        <span class="jt-eyebrow">APA ITU JAGATALK</span>
        <h2>Bukan webinar generic.<br>Ini ngobrol nyata sama yang sudah di sana.</h2>
        <p class="jt-lead">Lupain webinar dengan slide PPT 100 halaman dan motivator yang belum pernah ke luar negeri. JAGATALK menghadirkan suara nyata — dari mahasiswa, alumni, dan praktisi yang sedang atau pernah hidup di negeri tujuan.</p>
        <div class="jt-about-grid" data-reveal-group>
          <div class="jt-about-card"><div class="jt-about-icon">🎙️</div><h3>Real Voices</h3><p>Narasumber utama adalah mahasiswa & alumni Indonesia yang sedang menjalani kuliah di luar negeri. Cerita yang kamu dengar = pengalaman langsung, bukan teori.</p></div>
          <div class="jt-about-card"><div class="jt-about-icon jt-ai-orange">🌏</div><h3>10+ Negara Tujuan</h3><p>Setiap minggu bahas 1 negara/topik berbeda: Malaysia, Taiwan, China, Arab Saudi, Turki, boarding school internasional, dan lainnya.</p></div>
          <div class="jt-about-card"><div class="jt-about-icon jt-ai-yellow">🎫</div><h3>Gratis, Konsisten, Bernilai</h3><p>Setiap Jumat malam, free, online via Zoom. Konten berkualitas tanpa biaya — karena tujuan kami memperluas akses informasi pendidikan.</p></div>
        </div>
      </div>
    </section>

    <!-- JADWAL TERDEKAT -->
    <section class="jt-section jt-featured" id="daftar" data-reveal="section">
      <div class="jt-inner">
        <span class="jt-eyebrow" style="text-align:center;display:block;">JADWAL TERDEKAT</span>
        <h2 style="text-align:center;">Webinar minggu ini.</h2>
        <div class="jt-terdekat-grid" data-reveal-group>
          <img src="/jagatalk-webinar-6.webp" alt="Poster JAGATALK Webinar #6 — Dari Networking ke AI, Muhammad Nibras Salsabil, Guilin University of Electronic Technology (China)" class="jt-terdekat-flyer" />
          <div class="jt-terdekat-info">
            <div class="jt-terdekat-row"><span class="ico">🎯</span><div><span class="lbl">Topik</span><span class="val">Dari Networking ke AI: Menyiapkan Talenta Digital Masa Depan</span></div></div>
            <div class="jt-terdekat-row"><span class="ico">🎙️</span><div><span class="lbl">Narasumber</span><span class="val">Muhammad Nibras Salsabil · Mahasiswa AI, Guilin University of Electronic Technology, China</span></div></div>
            <div class="jt-terdekat-row"><span class="ico">📅</span><div><span class="lbl">Tanggal</span><span class="val">Jumat, 24 Juli 2026</span></div></div>
            <div class="jt-terdekat-row"><span class="ico">🕢</span><div><span class="lbl">Waktu</span><span class="val">19.30 – 21.30 WIB</span></div></div>
            <div class="jt-terdekat-row"><span class="ico">💻</span><div><span class="lbl">Platform</span><span class="val">via Zoom Meeting</span></div></div>
            <a class="jt-btn-primary" href="#final-cta" style="margin-top:8px;">🎯 Amankan Kursi Anda Sekarang!</a>
          </div>
        </div>
      </div>
    </section>

    <!-- JADWAL WEBINAR JAGATALK -->
    <section class="jt-section jt-speakers" id="jadwal" data-reveal="section">
      <div class="jt-inner">
        <span class="jt-eyebrow">JADWAL WEBINAR JAGATALK</span>
        <h2>Ngobrol langsung dengan yang udah ngalamin.</h2>
        <p class="jt-lead">Mereka bukan motivator. Mereka mahasiswa Indonesia yang sedang menjalani kuliah di luar negeri — dan siap cerita jujur. Catat tanggalnya, amankan kursimu.</p>
        <div class="jt-jadwal-grid" data-reveal-group>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">👨‍🎓</div>
            <h3>Kak Rafie</h3>
            <p class="jt-jadwal-univ">Universiti Utara Malaysia (UUM), Malaysia</p>
            <div class="jt-jadwal-date">28 Mei 2026</div>
          </div>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">👨‍🏫</div>
            <h3>Pak Dedi</h3>
            <p class="jt-jadwal-univ">Founder IDN Boarding School (Program Sekolah Internasional)</p>
            <div class="jt-jadwal-date">5 Juni 2026</div>
          </div>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">🧑‍🎓</div>
            <h3>Kak Ismail</h3>
            <p class="jt-jadwal-univ">National Dong Hwa University, Taiwan</p>
            <div class="jt-jadwal-date">12 Juni 2026</div>
          </div>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">👨‍🎓</div>
            <h3>Kak Kegan</h3>
            <p class="jt-jadwal-univ">Harbin Institute of Technology, China</p>
            <div class="jt-jadwal-date">19 Juni 2026</div>
          </div>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">🧑‍🎓</div>
            <h3>Kak Najwan</h3>
            <p class="jt-jadwal-univ">Universitas Islam Madinah, Arab Saudi</p>
            <div class="jt-jadwal-date">3 Juli 2026</div>
          </div>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">🧑‍🎓</div>
            <h3>Kak Yasin</h3>
            <p class="jt-jadwal-univ">Guilin University of Electronic Technology, China</p>
            <div class="jt-jadwal-date">10 Juli 2026</div>
          </div>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">👨‍🎓</div>
            <h3>Kak Syafiq</h3>
            <p class="jt-jadwal-univ">Cheng Shiu University, Taiwan</p>
            <div class="jt-jadwal-date">17 Juli 2026</div>
          </div>
          <div class="jt-jadwal-box jt-jadwal-next">
            <div class="jt-jadwal-icon">👨‍🎓</div>
            <h3>Kak Nibras</h3>
            <p class="jt-jadwal-univ">Guilin University of Electronic Technology, China</p>
            <div class="jt-jadwal-date">24 Juli 2026</div>
          </div>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">🧑‍🎓</div>
            <h3>Kak Abdullah</h3>
            <p class="jt-jadwal-univ">Universitas Islam Madinah, Arab Saudi</p>
            <div class="jt-jadwal-date">31 Juli 2026</div>
          </div>
          <div class="jt-jadwal-box">
            <div class="jt-jadwal-icon">👨‍🎓</div>
            <h3>Kak Abdul Hadi</h3>
            <p class="jt-jadwal-univ">Istanbul Sabahattin Zaim University, Turki</p>
            <div class="jt-jadwal-date">7 Agustus 2026</div>
          </div>
        </div>
        <p class="jt-jadwal-note">Jadwal dapat berubah menyesuaikan kesiapan pemateri. Pantau IG <a href="https://instagram.com/jagatrip.id" target="_blank">@jagatrip.id</a> untuk update terbaru.</p>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="jt-section jt-how" data-reveal="section">
      <div class="jt-inner">
        <span class="jt-eyebrow">CARA DAFTAR</span>
        <h2>5 langkah simple. Beneran gratis.</h2>
        <p class="jt-lead">Webinar ini gratis, tapi ada syarat kecil: bantu sebarkan info ke grup/komunitas/sosmed kamu. Karena pendidikan internasional bukan milik segelintir orang saja.</p>
        <div class="jt-how-grid" data-reveal-group>
          <div class="jt-how-step"><div class="jt-how-num">1</div><h4>Hubungi WA Admin</h4><p>Klik tombol daftar, lalu chat admin via WhatsApp untuk memulai pendaftaran.</p></div>
          <div class="jt-how-step"><div class="jt-how-num n2">2</div><h4>Share Info Webinar</h4><p>Sebarkan info webinar ke grup, komunitas, atau sosial media kamu untuk bantu menyebarkan akses pendidikan.</p></div>
          <div class="jt-how-step"><div class="jt-how-num n3">3</div><h4>Isi Google Form</h4><p>Lengkapi data dasar (nama, WA, status) di Google Form pendaftaran.</p></div>
          <div class="jt-how-step"><div class="jt-how-num n4">4</div><h4>Gabung Grup Webinar</h4><p>Masuk ke grup peserta untuk info, reminder, dan materi webinar.</p></div>
          <div class="jt-how-step"><div class="jt-how-num n5">5</div><h4>Terima Link Zoom</h4><p>Link Zoom dikirim ke grup/WhatsApp paling lambat H-1 sebelum acara.</p></div>
        </div>
        <div class="jt-viral-note">
          <div class="jt-icon-big">💡</div>
          <div>
            <h4>Mengapa Kami Meminta Kamu Berbagi ke 3 Grup?</h4>
            <p>Ini bukan untuk tindakan spam. Kami percaya bahwa informasi pendidikan internasional yang berkualitas berhak didapatkan oleh siapa saja, bukan cuma segelintir orang. Dengan menyebarkan info ini, kamu sedang bergotong royong bersama kami membantu teman, saudara, atau tetanggamu yang mungkin sedang mencari jalan untuk mengubah nasib lewat pendidikan dunia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY -->
    <section class="jt-section jt-why" data-reveal="section">
      <div class="jt-inner">
        <span class="jt-eyebrow">KENAPA HARUS IKUT</span>
        <h2>Bukan Sesi Dengar Pasif. Ini yang Akan Kamu Bawa Pulang Setelah 120 Menit:</h2>
        <div class="jt-why-grid" data-reveal-group>
          <div class="jt-why-card"><div class="jt-num-big">01</div><h4>Angka Jujur & Data Riil</h4><p>Bocoran biaya hidup asli, skema beasiswa tersembunyi, timeline pendaftaran, hingga kelengkapan dokumen tanpa ada yang ditutup-tutupi.</p></div>
          <div class="jt-why-card"><div class="jt-num-big">02</div><h4>Koneksi Circle Internasional</h4><p>Jangan cuma nonton. Kamu bisa berjejaring dengan pembicara dan sesama peserta yang punya mimpi besar yang sama. Banyak yang berlanjut konsultasi via DM!</p></div>
          <div class="jt-why-card"><div class="jt-num-big">03</div><h4>Mimbar Tanya Jawab Bebas</h4><p>Alokasi waktu 20-30 menit khusus untuk bertanya apa saja. Dari hal teknis perkuliahan sampai masalah personal/kegalauanmu.</p></div>
          <div class="jt-why-card"><div class="jt-num-big">04</div><h4>Rekaman Webinar</h4><p>Dapatkan rekaman penuh webinar — khusus untuk peserta yang mengikuti webinar full sesi dan mengisi form kehadiran.</p></div>
          <div class="jt-why-card"><div class="jt-num-big">05</div><h4>Akses Arsip & Resources Eksklusif</h4><p>Slide presentasi beserta tautan penting (resource links) akan dibagikan gratis hanya untuk kamu yang berkomitmen hadir sampai akhir sesi.</p></div>
          <div class="jt-why-card"><div class="jt-num-big">06</div><h4>Jalur Prioritas Edutrip</h4><p>Akses eksklusif dan info tercepat untuk bergabung dalam program study visit internasional premium bersama JAGATRIP ke negara tujuan.</p></div>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <section class="jt-section jt-trust" data-reveal="section">
      <div class="jt-trust-inner">
        <div class="jt-trust-logo"><svg><use href="#jagatrip-logo"></use></svg></div>
        <span class="jt-eyebrow" style="color:var(--jt-yellow);">BACKED BY JAGATRIP</span>
        <p>JAGATALK adalah inisiatif dari PT Jagatrip Mitra Edukasi yang melakukan perjalanan edukasi dan program benchmarking internasional ke sekolah-sekolah mancanegara.</p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="jt-section jt-faq" data-reveal="section">
      <div class="jt-inner">
        <span class="jt-eyebrow" style="text-align:center;display:block;">PERTANYAAN UMUM</span>
        <h2 style="text-align:center;">Yang sering ditanyakan.</h2>
        <p class="jt-lead" style="text-align:center;margin:0 auto 48px;">Kalau jawaban di sini belum cukup, langsung WhatsApp admin di bawah.</p>
        <div class="jt-faq-list">
          <details class="jt-faq-item"><summary>Apakah webinar ini beneran gratis?</summary><p>100% gratis. Nggak ada biaya pendaftaran, nggak ada upselling tersembunyi. Satu-satunya "syarat" adalah membantu menyebarkan info webinar ke 3 grup WhatsApp.</p></details>
          <details class="jt-faq-item"><summary>Saya bukan siswa SMA / mahasiswa, masih boleh ikut?</summary><p>Sangat boleh. Audiens JAGATALK terbuka untuk siswa SMA, mahasiswa, orangtua, guru/pendidik, dan siapapun yang tertarik mempelajari sistem pendidikan internasional.</p></details>
          <details class="jt-faq-item"><summary>Bagaimana sistem share ke 3 grup-nya?</summary><p>Setelah isi Google Form, kamu akan diberikan flyer + template caption. Share ke minimal 3 grup WhatsApp, screenshot bukti share-nya, lalu upload kembali di Google Form.</p></details>
          <details class="jt-faq-item"><summary>Topik webinar berikutnya apa saja?</summary><p>Setiap minggu membahas negara/topik berbeda: Malaysia, Taiwan, China, Arab Saudi, Turki, sekolah internasional, dan lainnya. Cek jadwal lengkap di section "Jadwal Webinar JAGATALK" di atas, atau pantau IG @jagatrip.id untuk update.</p></details>
          <details class="jt-faq-item"><summary>Apa hubungannya JAGATALK dengan edutrip JAGATRIP?</summary><p>JAGATALK adalah inisiatif edukasi (gratis) dari JAGATRIP. Peserta JAGATALK yang tertarik program edutrip akan mendapatkan priority info & special offer.</p></details>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="jt-section jt-final-cta" id="final-cta" data-reveal="section">
      <div class="jt-inner" style="position:relative;z-index:1;text-align:center;">
        <h2 style="color:white;">Webinar berikutnya<br>tinggal hitung hari.</h2>
        <p class="jt-lead" style="color:rgba(255,255,255,0.92);margin:0 auto 32px;">Slot Zoom terbatas tiap minggu. Daftar sekarang, dapet link H-1, dengar langsung dari mahasiswa Indonesia yang sedang kuliah di luar negeri.</p>

        <div class="jt-reg-card">
          <h3>Formulir Pendaftaran</h3>
          <p class="jt-reg-sub">Lengkapi data di bawah ini. Pendaftaran tercatat otomatis dan kamu langsung diarahkan ke WhatsApp Admin.</p>
          <form id="reg-form-jagatalk">
            <div class="jt-form-group">
              <label for="nama">Nama Lengkap *</label>
              <input type="text" id="nama" name="nama" required placeholder="Contoh: Budi Santoso" />
            </div>
            <div class="jt-form-group">
              <label for="instansi">Asal Instansi *</label>
              <input type="text" id="instansi" name="instansi" required placeholder="Contoh: SMA Negeri 1 Jakarta / Universitas Indonesia" />
            </div>
            <div class="jt-form-group">
              <label for="wa">Nomor WhatsApp Aktif *</label>
              <input type="tel" id="wa" name="wa" required placeholder="Contoh: 08123456789" />
            </div>
            <button type="submit" class="jt-btn-submit">Daftar Sekarang <svg class="jt-arrow" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></button>
            <div id="reg-status-jagatalk" class="jt-reg-status hidden"></div>
          </form>
        </div>

        <p style="margin-top:24px;opacity:0.85;font-size:14px;color:white;">Sudah tergabung? Bagikan info ini ke teman yang juga lagi nyari info kuliah LN 🌏</p>
      </div>
    </section>

    <!-- FOOTER -->
    <Footer />

  </main>
</BaseLayout>

<style>
  .jt { --jt-primary:#0E7C86; --jt-primary-dark:#086A73; --jt-primary-light:#5EBDC4; --jt-orange:#FF6B1A; --jt-orange-dark:#E55100; --jt-yellow:#FFD23F; --jt-cream:#FFF8F0; --jt-charcoal:#1A1A1A; --jt-gray:#6B7280; --jt-green:#10B981; }

  /* NAV */
  .jt-nav { position:fixed; top:0; left:0; right:0; background:rgba(255,248,240,0.95); backdrop-filter:blur(10px); padding:14px 24px; z-index:1000; box-shadow:0 2px 12px rgba(0,0,0,0.04); }
  .jt-nav-inner { max-width:1200px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; }
  .jt-logo-wrap { display:flex; align-items:center; gap:10px; text-decoration:none; }
  .jt-logo-svg { width:44px; height:44px; }
  .jt-logo-text { font-weight:900; font-size:24px; letter-spacing:-0.5px; }
  .jt-logo-text .jaga { color:var(--jt-primary); }
  .jt-logo-text .talk { color:var(--jt-orange); }
  .jt-logo-sub { font-size:10px; color:var(--jt-gray); font-weight:600; letter-spacing:2px; text-transform:uppercase; display:block; line-height:1; }
  .jt-nav-actions { display:flex; align-items:center; gap:6px; }
  .jt-nav-link-jadwal { color:var(--jt-charcoal); font-weight:700; font-size:14px; text-decoration:none; margin-right:8px; transition:color 0.2s; }
  .jt-nav-link-jadwal:hover { color:var(--jt-primary); }
  .jt-nav-cta { background:var(--jt-primary); color:white; padding:10px 20px; border-radius:999px; text-decoration:none; font-weight:700; font-size:14px; transition:all 0.2s; display:inline-flex; align-items:center; gap:6px; }
  .jt-nav-cta:hover { background:var(--jt-primary-dark); }
  .jt-arrow { width:20px; height:20px; transition:transform 0.2s; }
  a:hover .jt-arrow { transform:translateX(3px); }

  /* HERO */
  .jt-hero { padding:120px 24px 80px; background:linear-gradient(135deg,var(--jt-cream),#E0F2F4); position:relative; overflow:hidden; }
