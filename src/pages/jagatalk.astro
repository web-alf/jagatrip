  import { getUtm } from '../lib/utm';

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('reg-form-jagatalk') as HTMLFormElement | null;
    if (!form) return;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const statusEl = document.getElementById('reg-status-jagatalk');
    const admins = ['6281128506576'];
    const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwrwCUYnuIUCflczefMlYAHdCnOD-5PMqVEL94QTPWy6Hkds6SiOQLfyo7PZpVoqtjiZg/exec';

    function showStatus(type: 'ok' | 'err', msg: string): void {
      if (!statusEl) return;
      statusEl.textContent = msg;
      statusEl.className = `jt-reg-status ${type}`;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nama = (form.querySelector('#nama') as HTMLInputElement | null)?.value.trim();
      const instansi = (form.querySelector('#instansi') as HTMLInputElement | null)?.value.trim();
      const wa = (form.querySelector('#wa') as HTMLInputElement | null)?.value.trim();

      if (!nama || !instansi || !wa) {
        showStatus('err', 'Semua field wajib diisi.');
        return;
      }

      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Memproses...';
      }

      // Load balance between the two WhatsApp admin numbers
      const selectedAdmin = admins[Math.floor(Math.random() * admins.length)];
      const greeting = `Hai admin JAGATALK, saya ${nama} dari ${instansi} telah mengisi form pendaftaran webinar JAGATALK. Bagaimana langkah selanjutnya?`;
      const waUrl = `https://wa.me/${selectedAdmin}?text=${encodeURIComponent(greeting)}`;

      try {
        await fetch(APPS_SCRIPT_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            _sheet: 'LP_Jagatalk',
            nama,
            instansi,
            wa,
            ...getUtm(),
            source: 'JAGATALK Landing Page (/jagatalk)',
            timestamp: new Date().toISOString(),
          }),
        });
      } catch (err) {
        console.error('Error logging lead to Google Sheet:', err);
      }

      const win = window as any;
      if (win.fbq) {
        try { win.fbq('track', 'Lead'); } catch (e) { console.error('FB Pixel error:', e); }
      }

      showStatus('ok', 'Pendaftaran berhasil! Mengalihkan ke WhatsApp...');
      setTimeout(() => { window.location.href = waUrl; }, 500);
    });
  });
</script>
