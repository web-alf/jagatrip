---
import BaseLayout from '../layouts/BaseLayout.astro';
import { chinaEventSchema, chinaProgram as p } from '../data/china';
---
<BaseLayout title={`JAGATRIP #2 — ${p.title}`} description={`Program studi banding pendidikan ke Beijing dan Hangzhou, ${p.date}. Dua expo, kunjungan sekolah, kuota ${p.quota} peserta.`} canonical="https://jagatrip.com/china" ogType="website" extraSchemas={[chinaEventSchema]}>
  <header class="nav">
    <a href="/" aria-label="JAGATRIP"><img src="/images/china/jagatrip-logo.png" width="2094" height="570" alt="JAGATRIP Mitra Edukasi"></a>
    <a class="nav-cta" href="#form">Daftar minat</a>
  </header>

  <main id="main">
    <section class="hero">
      <div class="hero-copy">
        <p class="kicker"><span></span> JAGATRIP #2 · EDUCATION MISSION</p>
        <h1>Belajar dari <em>kelas dunia,</em> bukan sekadar melihatnya.</h1>
        <p class="hero-lead">Tujuh hari di Beijing dan Hangzhou. Masuk ke dua expo internasional, berdialog di sekolah, pulang membawa jaringan serta perspektif baru.</p>
        <div class="actions"><a class="button primary" href="#form">Ajukan pendaftaran minat</a><a class="button secondary" href="#program">Lihat program <span>↓</span></a></div>
        <p class="micro">Tidak mengikat pembayaran · Kuota hanya {p.quota} peserta</p>
      </div>
      <aside class="pass" aria-label="Ringkasan perjalanan">
        <div class="pass-top"><span>MISSION PASS / 02</span><img src="/images/china/jagatrip-mark.png" width="702" height="764" alt=""></div>
        <div class="route"><div><small>FROM</small><strong>BJS</strong><span>Beijing</span></div><div class="rail"><i></i><b>4.5H</b></div><div><small>TO</small><strong>HGH</strong><span>Hangzhou</span></div></div>
        <div class="pass-cut"></div>
        <dl><div><dt>Tanggal</dt><dd>{p.date}</dd></div><div><dt>Status</dt><dd><span class="live"></span> Pendaftaran minat</dd></div><div><dt>Agenda</dt><dd>2 expo · 3–6 sekolah</dd></div><div><dt>Kapasitas</dt><dd>{p.quota} delegasi</dd></div></dl>
      </aside>
    </section>

    <section class="proof" aria-label="Fakta program">{p.facts.map(([number,label]) => <div><strong>{number}</strong><span>{label}</span></div>)}</section>

    <section class="section intro" id="program">
      <div class="section-head"><p class="kicker dark"><span></span> MENGAPA PROGRAM INI</p><h2>Akses yang tidak selesai di pintu pameran.</h2><p>Program disusun untuk pemimpin pendidikan yang ingin melihat kebijakan, teknologi, dan praktik langsung dalam satu perjalanan.</p></div>
      <div class="reasons">{p.differentiators.map(([title,body],i) => <article><span>0{i+1}</span><h3>{title}</h3><p>{body}</p></article>)}</div>
    </section>

    <section class="section journey">
      <div class="section-head light"><p class="kicker"><span></span> RUTE MISI</p><h2>Dua kota. Dua sudut pandang.</h2></div>
      <div class="city-grid">{p.cities.map((city,i) => <article class:list={{ city:true, hangzhou:i===1 }}><div class="city-meta"><span>{city.code}</span><small>{city.date}</small></div><p class="cn" aria-hidden="true">{city.cn}</p><h3>{city.name}</h3><p class="city-note">{city.note}</p><ul>{city.items.map(item => <li>{item}</li>)}</ul></article>)}</div>
      <div class="train"><span>BEIJING</span><i></i><b>KERETA CEPAT · ±4,5 JAM</b><i></i><span>HANGZHOU</span></div>
    </section>

    <section class="section outcomes">
      <div class="section-head"><p class="kicker dark"><span></span> YANG DIBAWA PULANG</p><h2>Fasilitas terukur. Dampak yang bertumbuh.</h2></div>
      <div class="outcome-grid"><article><header><span>A</span><div><small>FASILITAS</small><h3>Yang Anda terima</h3></div></header><ul>{p.physicalBenefits.map(x => <li>{x}</li>)}</ul></article><article class="impact"><header><span>B</span><div><small>PROFESIONAL</small><h3>Yang Anda bawa</h3></div></header><ul>{p.professionalBenefits.map(x => <li>{x}</li>)}</ul></article></div>
    </section>

    <section class="section packages">
      <div class="section-head light"><p class="kicker"><span></span> OPSI KEBERANGKATAN</p><h2>Pilih cara berangkatnya. Pengalamannya tetap utuh.</h2></div>
      <div class="package-grid">{p.packages.map(([name,body],i) => <article><span>{i===0?'ALL-IN':'FLEXIBLE'}</span><h3>{name}</h3><p>{body}</p><a href="#form">Minta rincian biaya →</a></article>)}</div>
    </section>

    <section class="section faq"><div class="section-head"><p class="kicker dark"><span></span> FAQ</p><h2>Sebelum Anda berangkat.</h2></div><div class="faq-list">{p.faqs.map(([q,a]) => <details><summary>{q}<span></span></summary><p>{a}</p></details>)}</div></section>

    <section class="form-section" id="form">
      <div class="form-copy"><p class="kicker"><span></span> PENDAFTARAN MINAT</p><h2>Satu langkah menuju ruang kelas berikutnya.</h2><p>Isi data singkat. Setelah dikirim, WhatsApp terbuka dengan pesan yang sudah disiapkan untuk admin.</p><div class="quota"><strong>{p.quota}</strong><span>kursi<br/>delegasi</span></div></div>
      <form class="lead-form" data-china-form><label>Nama lengkap<input name="nama" required minlength="3" autocomplete="name" placeholder="Nama lengkap Anda"></label><label>Asal lembaga / domisili<input name="asal" required minlength="2" autocomplete="organization" placeholder="Lembaga atau kota"></label><label>Nomor WhatsApp<input name="whatsapp" type="tel" required pattern="[0-9+() -]{8,20}" inputmode="tel" autocomplete="tel" placeholder="0812 3456 7890"></label><button>Kirim & buka WhatsApp</button><small>Data Anda hanya diteruskan melalui pesan WhatsApp yang Anda kirim.</small></form>
    </section>
  </main>
  <footer><img src="/images/china/jagatrip-logo.png" width="2094" height="570" alt="JAGATRIP Mitra Edukasi"><p>© 2026 PT Jagatrip Mitra Edukasi</p><div><a href="/privacy">Privasi</a><a href="/terms">Syarat & Ketentuan</a></div></footer>

  <script>
    document.querySelector<HTMLFormElement>('[data-china-form]')?.addEventListener('submit', event => {
      event.preventDefault(); const form=event.currentTarget; if(!form.reportValidity()) return;
      const data=new FormData(form), nama=String(data.get('nama')).trim(), asal=String(data.get('asal')).trim(), whatsapp=String(data.get('whatsapp')).trim();
      const message=`Halo Admin, saya ${nama} dari ${asal} tertarik ikut Jagatrip ke China dan sudah mengisi form. Nomor WhatsApp saya ${whatsapp}. Bagaimana selanjutnya?`;
      location.href=`https://wa.me/628139190363?text=${encodeURIComponent(message)}`;
    });
  </script>
</BaseLayout>

<style>
  :global(body){background:#faf7f2;color:#211b17;font-family:Outfit,ui-sans-serif,sans-serif} :global(*){box-sizing:border-box} .nav{height:72px;padding:0 max(24px,calc((100vw - 1160px)/2));display:flex;align-items:center;justify-content:space-between;background:rgba(250,247,242,.92);backdrop-filter:blur(14px);position:sticky;top:0;z-index:20;border-bottom:1px solid #ded7ce}.nav img,footer img{display:block;width:170px;height:auto}.nav-cta,.button,.lead-form button{background:#e8611f;color:white;border:0;border-radius:2px;text-decoration:none;font-weight:800;padding:13px 20px;transition:.2s}.nav-cta:hover,.primary:hover,.lead-form button:hover{background:#b94717;transform:translateY(-2px)}
  .hero{min-height:620px;max-width:1160px;margin:auto;padding:76px 24px 90px;display:grid;grid-template-columns:1.12fr .88fr;gap:72px;align-items:center}.kicker{display:flex;align-items:center;gap:10px;font-size:12px;font-weight:800;letter-spacing:.16em;color:#fff;margin:0 0 22px}.kicker span{width:28px;height:2px;background:#c99a35}.kicker.dark{color:#8e3b1a}.hero h1{font-size:clamp(48px,6vw,76px);line-height:.98;letter-spacing:-.055em;margin:0;max-width:760px}.hero h1 em{font-family:Georgia,serif;font-weight:400;color:#b4232d}.hero-lead{font-size:19px;line-height:1.65;color:#665d56;max-width:670px;margin:28px 0}.actions{display:flex;gap:12px;align-items:center}.button{display:inline-flex;align-items:center;justify-content:center;min-height:50px}.secondary{background:transparent;color:#211b17;border:1px solid #bdb4aa}.secondary:hover{border-color:#e8611f;color:#e8611f}.secondary span{margin-left:20px}.micro{font-size:13px;color:#7f746b;margin:14px 0 0}
  .pass{background:#211b17;color:white;padding:28px;clip-path:polygon(0 0,calc(100% - 18px) 0,100% 18px,100% 100%,18px 100%,0 calc(100% - 18px));box-shadow:18px 18px 0 #e8611f;position:relative}.pass-top{display:flex;justify-content:space-between;align-items:center;font-size:11px;letter-spacing:.16em;color:#cfc5bb}.pass-top img{width:42px;height:46px;object-fit:contain;filter:brightness(0) invert(1);opacity:.8}.route{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;align-items:center;margin:42px 0 34px}.route div:last-child{text-align:right}.route small,.route span{display:block;color:#aaa096;font-size:11px}.route strong{display:block;font-size:52px;line-height:1;letter-spacing:-.06em}.rail{display:flex!important;align-items:center;position:relative}.rail i{display:block;width:100%;border-top:1px dashed #c99a35}.rail b{position:absolute;left:50%;transform:translateX(-50%);background:#211b17;padding:6px;color:#c99a35;font-size:10px}.pass-cut{border-top:1px dashed #766d66;margin:0 -28px}.pass dl{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin:28px 0 0}.pass dl div{border-left:2px solid #e8611f;padding-left:12px}.pass dt{font-size:10px;letter-spacing:.14em;color:#9d938a;text-transform:uppercase}.pass dd{margin:5px 0 0;font-size:14px;font-weight:700}.live{display:inline-block;width:7px;height:7px;border-radius:50%;background:#e8611f}
  .proof{background:#e8611f;color:white;display:grid;grid-template-columns:repeat(4,1fr);padding:0 max(24px,calc((100vw - 1160px)/2))}.proof div{padding:28px 24px;border-right:1px solid rgba(255,255,255,.25);display:flex;align-items:baseline;gap:12px}.proof strong{font:700 40px Georgia,serif}.proof span{font-size:13px}.section{padding:100px max(24px,calc((100vw - 1160px)/2))}.section-head{display:grid;grid-template-columns:1fr 1.4fr;gap:24px;margin-bottom:48px}.section-head .kicker{grid-column:1/-1;margin-bottom:0}.section-head h2{font-size:clamp(38px,5vw,58px);line-height:1;letter-spacing:-.045em;margin:0}.section-head>p:last-child{font-size:17px;line-height:1.7;color:#71675f;margin:0;max-width:540px}.reasons{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid #cfc6bc}.reasons article{padding:28px 28px 10px 0;border-right:1px solid #cfc6bc}.reasons article+article{padding-left:28px}.reasons span{color:#b4232d;font-weight:800}.reasons h3{font-size:22px;margin:30px 0 12px}.reasons p{color:#71675f;line-height:1.65}
  .journey,.packages{background:#211b17;color:white}.section-head.light h2{color:white}.city-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:#4a4039}.city{background:#2a231f;padding:40px;position:relative;overflow:hidden}.city.hangzhou{background:#302520}.city-meta{display:flex;justify-content:space-between;color:#d1c6bc}.city-meta span{color:#e8611f;font-weight:900;letter-spacing:.15em}.city .cn{position:absolute;right:22px;top:-55px;font:160px Georgia,serif;color:rgba(255,255,255,.035)}.city h3{font:56px Georgia,serif;margin:36px 0 4px}.city-note{color:#c99a35}.city ul{list-style:none;padding:20px 0 0;margin:20px 0 0;border-top:1px solid #544940}.city li{padding:8px 0;color:#d7cec7}.city li::before{content:'—';color:#e8611f;margin-right:12px}.train{display:flex;align-items:center;gap:18px;margin-top:30px;font-size:11px;letter-spacing:.12em;color:#bdb2a9}.train i{height:1px;background:#685c53;flex:1}.train b{color:#c99a35;font-size:10px}
  .outcome-grid,.package-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}.outcome-grid article{background:white;border:1px solid #dcd4ca;padding:34px}.outcome-grid header{display:flex;gap:16px;align-items:center;border-bottom:1px solid #ddd4ca;padding-bottom:22px}.outcome-grid header>span{display:grid;place-items:center;width:46px;height:46px;background:#e8611f;color:white;font-weight:900}.outcome-grid small{letter-spacing:.15em;color:#9a4b29}.outcome-grid h3{margin:3px 0;font-size:24px}.outcome-grid ul{columns:2;list-style:none;padding:15px 0 0}.outcome-grid li{break-inside:avoid;padding:9px 0;font-size:14px}.outcome-grid li::before{content:'✓';color:#e8611f;margin-right:8px}.outcome-grid .impact{background:#fff9f4}.package-grid article{border:1px solid #5c5048;padding:34px}.package-grid article>span{font-size:10px;letter-spacing:.16em;color:#c99a35}.package-grid h3{font:34px Georgia,serif}.package-grid p{color:#c9beb5;line-height:1.65;min-height:74px}.package-grid a{color:white;text-decoration:none;font-weight:800}.package-grid a:hover{color:#e8611f}
  .faq-list{max-width:820px;margin-left:auto}.faq details{border-top:1px solid #cfc6bc}.faq details:last-child{border-bottom:1px solid #cfc6bc}.faq summary{padding:22px 0;list-style:none;cursor:pointer;font-size:18px;font-weight:700;display:flex;justify-content:space-between}.faq summary::-webkit-details-marker{display:none}.faq summary span::after{content:'+';font-size:24px;color:#e8611f}.faq details[open] summary span::after{content:'−'}.faq details p{margin:0;padding:0 45px 22px 0;color:#71675f;line-height:1.65}
  .form-section{background:#e8611f;color:white;padding:90px max(24px,calc((100vw - 1160px)/2));display:grid;grid-template-columns:.85fr 1.15fr;gap:80px;align-items:center}.form-copy h2{font-size:clamp(40px,5vw,62px);line-height:1;letter-spacing:-.045em;margin:0}.form-copy>p:not(.kicker){line-height:1.65;max-width:480px}.quota{display:flex;align-items:center;gap:12px;border-top:1px solid rgba(255,255,255,.35);padding-top:20px;margin-top:30px}.quota strong{font:72px Georgia,serif}.quota span{font-size:13px;text-transform:uppercase;letter-spacing:.1em}.lead-form{background:#fff;color:#211b17;padding:36px;box-shadow:14px 14px 0 #211b17}.lead-form label{display:block;font-size:12px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;margin-bottom:18px}.lead-form input{display:block;width:100%;padding:13px 0;border:0;border-bottom:1px solid #bfb5ab;background:white;font:16px Outfit,sans-serif;border-radius:0}.lead-form input:focus{outline:0;border-color:#e8611f;box-shadow:0 2px #e8611f}.lead-form button{width:100%;font:800 15px Outfit,sans-serif;cursor:pointer;margin-top:8px;min-height:52px}.lead-form small{display:block;text-align:center;color:#857a71;margin-top:14px}footer{background:#171310;color:#b8ada5;padding:30px max(24px,calc((100vw - 1160px)/2));display:flex;align-items:center;gap:30px;font-size:12px}footer img{filter:brightness(0) invert(1);opacity:.8}footer p{margin-right:auto}footer div{display:flex;gap:18px}footer a{color:inherit}
  :where(a,button,summary,input):focus-visible{outline:3px solid #c99a35;outline-offset:4px}@media(max-width:800px){.nav{padding-inline:18px}.nav img{width:142px}.hero{grid-template-columns:1fr;padding:56px 20px 70px;gap:50px}.hero h1{font-size:50px}.pass{box-shadow:10px 10px 0 #e8611f}.proof{grid-template-columns:1fr 1fr;padding:0}.proof div:nth-child(2){border-right:0}.proof div{padding:20px}.section{padding:72px 20px}.section-head{grid-template-columns:1fr}.reasons,.city-grid,.outcome-grid,.package-grid,.form-section{grid-template-columns:1fr}.reasons article,.reasons article+article{padding:26px 0;border-right:0;border-bottom:1px solid #cfc6bc}.outcome-grid ul{columns:1}.train span{display:none}.form-section{padding:72px 20px;gap:35px}.lead-form{padding:26px;box-shadow:8px 8px 0 #211b17}footer{align-items:flex-start;flex-wrap:wrap}footer p{width:100%;order:3}.actions{align-items:stretch;flex-direction:column}.secondary{border:0;padding-left:0;justify-content:flex-start}.route strong{font-size:42px}.section-head h2{font-size:42px}.city{padding:28px}.city h3{font-size:44px}}@media(prefers-reduced-motion:reduce){*{scroll-behavior:auto!important;transition:none!important}}
</style>
