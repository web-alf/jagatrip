<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('reg-form-jagatalk2') as HTMLFormElement | null;
    if (form) {
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const statusEl = document.getElementById('reg-status-jagatalk2');
      
      const admins = ['6281128506576', '6281128506715'];
      
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const namaInput = form.querySelector('#nama') as HTMLInputElement | null;
        const instansiInput = form.querySelector('#instansi') as HTMLInputElement | null;
        const waInput = form.querySelector('#wa') as HTMLInputElement | null;
        
        const nama = namaInput?.value.trim();
        const instansi = instansiInput?.value.trim();
        const wa = waInput?.value.trim();
        
        if (!nama || !instansi || !wa) {
          showStatus('error', 'Semua field wajib diisi.');
          return;
        }
        
        if (btn) {
          btn.disabled = true;
          btn.textContent = 'Memproses...';
        }
        
        // Randomly load balance between the two WhatsApp admin numbers
        const selectedAdmin = admins[Math.floor(Math.random() * admins.length)];
        
        // Custom greeting message format (includes instansi for admin context):
        const greeting = `Hai admin Jagatalk, saya ${nama} dari ${instansi} telah mengisi form pendaftaran JAGATALK Episode 02. Bagaimana langkah selanjutnya?`;
        const waUrl = `https://wa.me/${selectedAdmin}?text=${encodeURIComponent(greeting)}`;
        
        const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwrwCUYnuIUCflczefMlYAHdCnOD-5PMqVEL94QTPWy6Hkds6SiOQLfyo7PZpVoqtjiZg/exec';
        
        try {
          // Asynchronously post details to Google Apps Script sheet
          await fetch(APPS_SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              _sheet: 'LP_Jagatalk02',
              nama: nama,
              instansi: instansi,
              wa: wa,
              source: 'Jagatalk Episode 02 Landing Page (jagatalk02)',
              timestamp: new Date().toISOString(),
            }),
          });
        } catch (err) {
          console.error('Error logging lead to Google Sheet:', err);
        }
        
        // Fire Facebook Pixel Lead tracking event
        const win = window as any;
        if (win.fbq) {
          try {
            win.fbq('track', 'Lead');
          } catch (e) {
            console.error('FB Pixel error:', e);
          }
        }
        
        showStatus('success', 'Pendaftaran berhasil! Mengalihkan ke WhatsApp...');
        
        setTimeout(() => {
          window.location.href = waUrl;
        }, 500);
      });

      function showStatus(type: 'success' | 'error', msg: string): void {
        if (!statusEl) return;
        statusEl.textContent = msg;
        statusEl.className = `text-sm text-center mt-4 font-bold ${
          type === 'success' ? 'text-green-600' : 'text-red-500'
        }`;
        statusEl.classList.remove('hidden');
      }
    }
  });
</script>
