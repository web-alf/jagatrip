---
import BaseLayout from '../layouts/BaseLayout.astro';
import { chinaEventSchema, chinaProgram as p } from '../data/china';
---
<BaseLayout title={`Field Notes — ${p.title}`} description={`JAGATRIP #2: misi pendidikan ke Beijing dan Hangzhou, ${p.date}.`} canonical="https://jagatrip.com/china2" ogType="website" extraSchemas={[chinaEventSchema]}>
  <header class="nav"><a href="/" aria-label="JAGATRIP"><img src="/images/china/jagatrip-logo.png" width="2094" height="570" alt="JAGATRIP Mitra Edukasi"></a><span>FIELD NOTE 02 / 2026</span><a href="#form">Daftar minat</a></header>
  <main id="main">
    <section class="cover">
      <div class="folio">EDUCATION MISSION · ISSUE 02</div><div class="sun"><img src="/images/china/jagatrip-mark.png" width="702" height="764" alt=""></div>
      <div class="title"><p>JAGATRIP PRESENTS</p><h1><span>Beijing</span><i>to</i><span>Hangzhou</span></h1><p class="subtitle">Kelas global untuk pemimpin pendidikan Indonesia.</p></div>
      <div class="cover-meta"><div><small>PERJALANAN</small><strong>{p.date}</strong></div><div><small>FORMAT</small><strong>2 kota · 2 expo · 3–6 sekolah</strong></div><a href="#form">Amankan kursi <span>↘</span></a></div>
      <div class="coordinates"><span>BJS 39.9042° N</span><i></i><span>HGH 30.2741° N</span></div>
    </section>

    <section class="thesis"><p class="chapter">00 / OPENING NOTE</p><blockquote>“Bukan tur wisata dengan tempelan agenda pendidikan.”</blockquote><div><p>Tujuh hari untuk melihat bagaimana kebijakan, teknologi, dan praktik pendidikan bertemu. Dari skala Beijing menuju energi inovasi Hangzhou.</p><p>Anda datang sebagai delegasi—untuk bertanya, membandingkan, lalu membawa pulang kemungkinan kolaborasi.</p></div></section>

    <section class="atlas">
      <header><p class="chapter">ROUTE ATLAS / 中国</p><h2>Dua kota,<br/><em>satu benang merah.</em></h2></header>
      <div class="route-line">{p.cities.map((city,i) => <article><div class="node"><span>{i+1}</span></div><p>{city.date}</p><h3>{city.name}</h3><span class="cn" aria-hidden="true">{city.cn}</span><small>{city.note}</small><ul>{city.items.map(x => <li>{x}</li>)}</ul></article>)}</div>
      <p class="rail-note">4,5 JAM MELINTASI 1.300 KM DENGAN KERETA CEPAT</p>
    </section>

    {p.expos.map((expo,i) => <section class:list={{ expo:true, paper:i===1 }}>
      <div class="expo-index"><span>CHAPTER</span><strong>{expo.chapter}</strong><small>{expo.city}</small></div>
      <div class="expo-copy"><p class="chapter">EXHIBITION NOTE</p><h2>{expo.name}</h2><p class="long">{expo.longName}</p><div class="venue"><span>{expo.date}</span><span>{expo.venue}</span></div><p class="body">{expo.body}</p></div>
      <div class="stats">{expo.stats.map(([n,l]) => <div><strong>{n}</strong><span>{l}</span></div>)}</div>
    </section>)}

    <section class="access"><p class="chapter">03 / SCHOOL ACCESS</p><div class="access-title"><h2>Masuk ke<br/>sekolahnya.</h2><p>Nilai paling langka dari perjalanan ini bukan kartu masuk expo. Ini kesempatan duduk bersama pengelola sekolah, melihat fasilitas, lalu bertanya langsung tentang keputusan di balik praktik mereka.</p></div><div class="school-numbers"><div><strong>2–4</strong><span>sekolah<br/>Beijing</span></div><div><strong>1–2</strong><span>sekolah<br/>Hangzhou</span></div></div><ol><li>Sambutan tuan rumah</li><li>Tur fasilitas</li><li>Dialog manajemen</li><li>Dokumentasi</li><li>Pertukaran cinderamata</li></ol><blockquote>Anda datang sebagai delegasi,<br/><em>bukan turis yang kebetulan lewat.</em></blockquote></section>

    <section class="itinerary"><header><p class="chapter">04 / SEVEN DAYS</p><h2>Catatan perjalanan.</h2><p>Kerangka agenda dapat menyesuaikan konfirmasi partner dan penyelenggara expo.</p></header><div class="days">{p.itinerary.map(([day,date,title,body]) => <details><summary><span>{day}</span><small>{date}</small><strong>{title}</strong><i></i></summary><p>{body}</p></details>)}</div></section>

    <section class="fit"><div><p class="chapter">05 / WHO SHOULD JOIN</p><h2>Untuk mereka yang memimpin perubahan.</h2></div><ul>{p.audience.map((x,i) => <li><span>0{i+1}</span>{x}</li>)}</ul><aside><strong>CATATAN PENTING</strong><p>Agenda dimulai pagi dan sebagian besar waktu berada di sekolah serta ruang pameran. Program ini dirancang untuk belajar dan membangun jaringan, bukan berbelanja.</p></aside></section>

    <section class="packages"><header><p class="chapter">06 / DEPARTURE OPTIONS</p><h2>Dua cara berangkat.<br/><em>Satu pengalaman utuh.</em></h2></header><div>{p.packages.map(([name,body],i) => <article><span>OPTION 0{i+1}</span><h3>{name}</h3><p>{body}</p><a href="#form">Minta rincian biaya ↗</a></article>)}</div></section>

    <section class="faq"><header><p class="chapter">07 / QUESTIONS</p><h2>Sebelum<br/>berangkat.</h2></header><div>{p.faqs.map(([q,a]) => <details><summary>{q}<span>+</span></summary><p>{a}</p></details>)}</div></section>

    <section class="closing" id="form"><div class="closing-copy"><p class="chapter">FINAL NOTE / YOUR MOVE</p><h2>The next class<br/>is in <em>China.</em></h2><p>Isi data minat. WhatsApp akan terbuka dengan pesan siap kirim ke admin JAGATRIP.</p><div class="seat"><strong>{p.quota}</strong><span>ONLY<br/>SEATS</span></div></div><form data-china-form><label><span>01</span> Nama lengkap<input name="nama" required minlength="3" autocomplete="name"></label><label><span>02</span> Asal lembaga / domisili<input name="asal" required minlength="2" autocomplete="organization"></label><label><span>03</span> Nomor WhatsApp<input name="whatsapp" type="tel" required pattern="[0-9+() -]{8,20}" inputmode="tel" autocomplete="tel"></label><button>Kirim minat <span>↗</span></button><small>Tidak mengikat pembayaran. Data hanya diteruskan lewat pesan yang Anda kirim.</small></form></section>
  </main>
  <footer><div><img src="/images/china/jagatrip-logo.png" width="2094" height="570" alt="JAGATRIP Mitra Edukasi"><span>FIELD NOTE 02 / 2026</span></div><p>© PT Jagatrip Mitra Edukasi</p><nav><a href="/privacy">Privasi</a><a href="/terms">Syarat & Ketentuan</a></nav></footer>
  <script>document.querySelector<HTMLFormElement>('[data-china-form]')?.addEventListener('submit',event=>{event.preventDefault();const form=event.currentTarget;if(!form.reportValidity())return;const d=new FormData(form),nama=String(d.get('nama')).trim(),asal=String(d.get('asal')).trim(),wa=String(d.get('whatsapp')).trim();const message=`Halo Admin, saya ${nama} dari ${asal} tertarik ikut Jagatrip ke China dan sudah mengisi form. Nomor WhatsApp saya ${wa}. Bagaimana selanjutnya?`;location.href=`https://wa.me/628139190363?text=${encodeURIComponent(message)}`})</script>
</BaseLayout>
<style>
  :global(body){margin:0;background:#f4eee5;color:#191512;font-family:Outfit,ui-sans-serif,sans-serif}:global(*){box-sizing:border-box}.nav{height:76px;padding:0 max(24px,calc((100vw - 1240px)/2));display:grid;grid-template-columns:1fr auto 1fr;align-items:center;border-bottom:1px solid #cec5b9;position:sticky;top:0;background:rgba(244,238,229,.94);backdrop-filter:blur(12px);z-index:30}.nav img{width:165px;height:auto;display:block}.nav>span{font-size:10px;letter-spacing:.2em}.nav>a:last-child{justify-self:end;color:#191512;text-transform:uppercase;font-size:11px;font-weight:800;letter-spacing:.12em;text-underline-offset:6px}.cover{min-height:calc(95svh - 76px);padding:55px max(24px,calc((100vw - 1240px)/2)) 35px;position:relative;display:flex;flex-direction:column;overflow:hidden}.folio,.chapter{font-size:10px;font-weight:800;letter-spacing:.19em;text-transform:uppercase;color:#a2431e}.sun{position:absolute;width:min(40vw,520px);aspect-ratio:1;background:#e8611f;border-radius:50%;right:max(24px,calc((100vw - 1240px)/2));top:8%;display:grid;place-items:center}.sun img{width:38%;height:auto;filter:brightness(0) invert(1);opacity:.18}.title{position:relative;z-index:2;margin:auto 0}.title>p:first-child{font-size:11px;letter-spacing:.3em;margin-bottom:30px}.title h1{font:700 clamp(68px,11vw,150px)/.76 Georgia,serif;letter-spacing:-.075em;margin:0;text-transform:uppercase}.title h1 span{display:block}.title h1 span:last-child{margin-left:19%}.title h1 i{display:block;font-size:.22em;line-height:1;margin:8px 0 0 14%;color:#e8611f;text-transform:none;font-weight:400}.subtitle{font:italic clamp(18px,2vw,25px) Georgia,serif;margin:36px 0 0 20%;max-width:460px}.cover-meta{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1fr auto;gap:30px;border-top:1px solid #aca297;padding-top:20px;align-items:end}.cover-meta small{display:block;font-size:9px;letter-spacing:.18em;color:#857a70}.cover-meta strong{display:block;margin-top:6px;font-size:14px}.cover-meta a{background:#191512;color:white;padding:17px 20px;text-decoration:none;font-weight:800;min-width:190px;display:flex;justify-content:space-between}.coordinates{position:absolute;right:17px;top:110px;height:50%;writing-mode:vertical-rl;font-size:8px;letter-spacing:.18em;display:flex;align-items:center;gap:12px}.coordinates i{height:100%;width:1px;background:#bcb2a6}
